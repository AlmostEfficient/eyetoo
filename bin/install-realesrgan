#!/usr/bin/env bash
set -euo pipefail

cd "$(dirname "${BASH_SOURCE[0]}")/.."
mkdir -p tools
tools_dir="$PWD/tools"
install_dir="$tools_dir/realesrgan-ncnn-vulkan"
bin="$install_dir/realesrgan-ncnn-vulkan"
models="$install_dir/models"

if [ -x "$bin" ] && find "$models" -type f \( -name '*.param' -o -name '*.bin' \) 2>/dev/null | grep -q .; then
  echo "already installed: ${bin#$PWD/}"
  exit 0
fi

url=$(python3 - <<'PY'
import json, platform, sys, urllib.request
api = 'https://api.github.com/repos/xinntao/Real-ESRGAN/releases/tags/v0.2.5.0'
release = json.load(urllib.request.urlopen(api, timeout=30))
system = platform.system().lower()
machine = platform.machine().lower()
if system != 'darwin':
    raise SystemExit(f'unsupported OS for this installer: {platform.system()}')
# Upstream releases use macos.zip and include both x86_64/arm64-compatible bits where available.
needles = ['ncnn-vulkan', 'macos']
assets = release.get('assets', [])
for asset in assets:
    name = asset.get('name', '').lower()
    if name.endswith('.zip') and all(n in name for n in needles):
        print(asset['browser_download_url'])
        break
else:
    print('available assets:', file=sys.stderr)
    for asset in assets:
        print('  ' + asset.get('name', ''), file=sys.stderr)
    raise SystemExit('could not find a macOS zip asset in latest Real-ESRGAN release')
PY
)

tmp=$(mktemp -d)
trap 'rm -rf "$tmp"' EXIT
archive="$tmp/realesrgan.zip"

echo "downloading $url"
curl -L --fail --progress-bar "$url" -o "$archive"

rm -rf "$install_dir"
unzip -q "$archive" -d "$tmp/unpacked"
found=$(find "$tmp/unpacked" -type f -name realesrgan-ncnn-vulkan -perm +111 2>/dev/null | head -n 1 || true)
if [ -z "$found" ]; then
  found=$(find "$tmp/unpacked" -type f -name realesrgan-ncnn-vulkan | head -n 1 || true)
fi
if [ -z "$found" ]; then
  find "$tmp/unpacked" -maxdepth 3 -type f -print >&2
  echo "could not find realesrgan-ncnn-vulkan binary in archive" >&2
  exit 1
fi

src_dir=$(dirname "$found")
mkdir -p "$install_dir"
cp -R "$src_dir"/. "$install_dir"/
chmod +x "$bin"

if ! find "$models" -type f \( -name '*.param' -o -name '*.bin' \) 2>/dev/null | grep -q .; then
  find "$install_dir" -maxdepth 3 -type f -print >&2
  echo "installed binary, but no Real-ESRGAN model files were found" >&2
  exit 1
fi

echo "installed: ${bin#$PWD/}"
"$bin" -h >/dev/null 2>&1 || true
